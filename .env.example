# 小红书自动发文 Agent 环境变量配置示例
# 
# ⚠️ 重要提示：
# 从 v2.0 开始，模型配置（API Key）已迁移到 config/model-config.json
# 请复制 config/model-config.example.json 到 config/model-config.json 并填写 API Key
#
# 本文件仅用于配置其他环境变量（如端口号等）

# ==================== 服务器配置 ====================
# API 服务器端口
PORT=3001

# ==================== 日志配置 ====================
# 日志级别：debug | info | warn | error
LOG_LEVEL=info

# ==================== 其他配置 ====================
# 是否自动发布（true | false）
AUTO_PUBLISH=false

# ==================== 向后兼容（不推荐使用） ====================
# 如果这些环境变量存在，会覆盖 config/model-config.json 中的配置
# TEXT_PROVIDER=deepseek
# TEXT_API_KEY=your_api_key_here
# IMAGE_PROVIDER=qwen
# IMAGE_API_KEY=your_api_key_here
