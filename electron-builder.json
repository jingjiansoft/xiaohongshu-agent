{
  "appId": "com.jingjiansoft.xiaohongshu-agent",
  "productName": "xiaohongshu-agent",
  "artifactName": "${productName}-${os}-${arch}.${ext}",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "dist/**/*",
    "web/out/**/*",
    "electron/**/*",
    "config/**/*",
    "prompts/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "node_modules/playwright-core",
      "to": "playwright-core"
    },
    {
      "from": "node_modules/.cache/ms-playwright",
      "to": "ms-playwright",
      "filter": "**/{chromium,chrome-linux,chrome-win,chrome-mac}/**/*"
    }
  ],
  "win": {
    "target": ["nsis"],
    "icon": "build/icon.ico"
  },
  "mac": {
    "target": ["dmg"],
    "icon": "build/icon.icns",
    "category": "public.app-category.social-networking"
  },
  "linux": {
    "target": ["deb", "AppImage"],
    "icon": "build/icon.png",
    "category": "Utility"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "xiaohongshu-agent"
  }
}
